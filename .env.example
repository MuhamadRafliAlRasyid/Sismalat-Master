APP_NAME=Sismalat
APP_ENV=local
APP_KEY=base64:GantiDenganKeyAndaNanti
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=buhin_core
DB_USERNAME=root
DB_PASSWORD=

# Google OAuth (Gunakan Placeholder, Jangan Isi Nilai Asli!)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Slack Webhook (Gunakan Placeholder)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
